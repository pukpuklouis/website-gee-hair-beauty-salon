---
import HeaderLink from "./HeaderLink.astro";
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-custom-expo bg-transparent" data-scrolled="false">
	<nav class="px-6 sm:px-8 lg:px-16 xl:px-24">
		<div class="flex items-center justify-between h-16 lg:h-20">
		<!-- Logo -->
			<a href="/" class="flex items-center gap-2">
				<img src="/gee-hair-beauty-salon-logo.svg" alt="Gee Hair & Beauty Salon" class="h-8 lg:h-10 transition-colors duration-300" />
            </a>

			<!-- Desktop Navigation -->
			<div class="hidden lg:flex items-center gap-8">
				<a href="#about" class="nav-link text-sm transition-colors duration-300 hover:text-[hsl(var(--blush-mist))] text-[hsl(var(--deep-espresso))]/80">
					關於我們
				</a>
				<a href="#services" class="nav-link text-sm transition-colors duration-300 hover:text-[hsl(var(--blush-mist))] text-[hsl(var(--deep-espresso))]/80">
					服務項目
				</a>
				<a href="#portfolio" class="nav-link text-sm transition-colors duration-300 hover:text-[hsl(var(--blush-mist))] text-[hsl(var(--deep-espresso))]/80">
					作品集
				</a>
				<a href="#designers" class="nav-link text-sm transition-colors duration-300 hover:text-[hsl(var(--blush-mist))] text-[hsl(var(--deep-espresso))]/80">
					設計師
				</a>
				<a href="#testimonials" class="nav-link text-sm transition-colors duration-300 hover:text-[hsl(var(--blush-mist))] text-[hsl(var(--deep-espresso))]/80">
					客戶評價
				</a>
				<HeaderLink href="/blog" class="text-sm transition-colors duration-300 hover:text-[hsl(var(--blush-mist))] text-[hsl(var(--deep-espresso))]/80">
					美髮日誌
				</HeaderLink>
			</div>

			<!-- CTA Buttons -->
			<div class="hidden lg:flex items-center gap-3">
				<a
					href="/blog"
					class="flex items-center gap-2 px-4 py-2 rounded-full text-sm transition-all duration-300 hover:bg-[hsl(var(--warm-beige))] text-[hsl(var(--deep-espresso))]/80"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
						<path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
					</svg>
					美髮日誌
				</a>
				
				<button
					id="booking-cta-desktop"
					class="rounded-full px-6 py-2 transition-all duration-300 bg-[hsl(var(--muted-bronze))] text-white hover:bg-[hsl(var(--deep-espresso))] flex items-center gap-2"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="6" cy="6" r="2"></circle>
						<circle cx="6" cy="18" r="2"></circle>
						<line x1="20" y1="4" x2="8.12" y2="15.88"></line>
						<line x1="14.47" y1="14.48" x2="20" y2="20"></line>
						<line x1="8.12" y1="8.12" x2="12" y2="12"></line>
						<line x1="8.12" y1="8.12" x2="12" y2="12"></line>
					</svg>
					立即預約
				</button>
			</div>

			<!-- Mobile Menu Button -->
			<button
				id="mobile-menu-toggle"
				class="lg:hidden w-10 h-10 flex items-center justify-center"
				aria-label="Toggle menu"
			>
				<svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[hsl(var(--deep-espresso))]">
					<line x1="4" y1="12" x2="20" y2="12"></line>
					<line x1="4" y1="6" x2="20" y2="6"></line>
					<line x1="4" y1="18" x2="20" y2="18"></line>
				</svg>
				<svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[hsl(var(--deep-espresso))] hidden">
					<line x1="18" y1="6" x2="6" y2="18"></line>
					<line x1="6" y1="6" x2="18" y2="18"></line>
				</svg>
			</button>
		</div>
	</nav>
</header>

<!-- Mobile Menu -->
<div
	id="mobile-menu"
	class="fixed inset-0 z-40 lg:hidden transition-all duration-500 opacity-0 invisible"
>
	<!-- Backdrop -->
	<div
		id="mobile-backdrop"
		class="absolute inset-0 bg-black/20 backdrop-blur-sm"
	></div>

	<!-- Menu Panel -->
	<div
		id="mobile-panel"
		class="absolute top-0 right-0 w-full max-w-sm h-full bg-white shadow-xl transition-transform duration-500 ease-custom-expo translate-x-full"
	>
		<div class="flex flex-col h-full pt-20 pb-8 px-6">
			<!-- Nav Links -->
			<div class="flex-1 space-y-1">
				<a href="#about" class="mobile-nav-link block w-full text-left py-4 text-lg text-[hsl(var(--deep-espresso))] border-b border-[hsl(var(--warm-beige))] transition-all duration-300 hover:text-[hsl(var(--blush-mist))] hover:pl-2 opacity-0 translate-x-4">
					關於我們
				</a>
				<a href="#services" class="mobile-nav-link block w-full text-left py-4 text-lg text-[hsl(var(--deep-espresso))] border-b border-[hsl(var(--warm-beige))] transition-all duration-300 hover:text-[hsl(var(--blush-mist))] hover:pl-2 opacity-0 translate-x-4">
					服務項目
				</a>
				<a href="#portfolio" class="mobile-nav-link block w-full text-left py-4 text-lg text-[hsl(var(--deep-espresso))] border-b border-[hsl(var(--warm-beige))] transition-all duration-300 hover:text-[hsl(var(--blush-mist))] hover:pl-2 opacity-0 translate-x-4">
					作品集
				</a>
				<a href="#designers" class="mobile-nav-link block w-full text-left py-4 text-lg text-[hsl(var(--deep-espresso))] border-b border-[hsl(var(--warm-beige))] transition-all duration-300 hover:text-[hsl(var(--blush-mist))] hover:pl-2 opacity-0 translate-x-4">
					設計師
				</a>
				<a href="#testimonials" class="mobile-nav-link block w-full text-left py-4 text-lg text-[hsl(var(--deep-espresso))] border-b border-[hsl(var(--warm-beige))] transition-all duration-300 hover:text-[hsl(var(--blush-mist))] hover:pl-2 opacity-0 translate-x-4">
					客戶評價
				</a>
				<a href="/blog" class="mobile-nav-link block w-full text-left py-4 text-lg text-[hsl(var(--deep-espresso))] border-b border-[hsl(var(--warm-beige))] transition-all duration-300 hover:text-[hsl(var(--blush-mist))] hover:pl-2 opacity-0 translate-x-4">
					美髮日誌
				</a>
			</div>

			<!-- CTA -->
			<div id="mobile-cta" class="pt-6 transition-all duration-500 opacity-0 translate-y-4">
				<button
					id="booking-cta-mobile"
					class="w-full bg-[hsl(var(--muted-bronze))] text-white hover:bg-[hsl(var(--deep-espresso))] rounded-full py-6 flex items-center justify-center gap-2"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="6" cy="6" r="2"></circle>
						<circle cx="6" cy="18" r="2"></circle>
						<line x1="20" y1="4" x2="8.12" y2="15.88"></line>
						<line x1="14.47" y1="14.48" x2="20" y2="20"></line>
						<line x1="8.12" y1="8.12" x2="12" y2="12"></line>
						<line x1="8.12" y1="8.12" x2="12" y2="12"></line>
					</svg>
					立即預約
				</button>
			</div>
		</div>
	</div>
</div>

<style>
	/* Header scroll state */
	#main-header[data-scrolled="true"] {
		background-color: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
	}

	/* Mobile menu open state */
	#mobile-menu.open {
		opacity: 1;
		visibility: visible;
	}

	#mobile-panel.open {
		transform: translateX(0);
	}

	/* Mobile nav link animations */
	.mobile-nav-link.animate {
		opacity: 1;
		transform: translateX(0);
	}

	#mobile-cta.animate {
		opacity: 1;
		transform: translateY(0);
	}
</style>

<script>
	// Header scroll behavior
	const header = document.getElementById('main-header');
	
	function updateHeaderScroll() {
		const isScrolled = window.scrollY > 100;
		header?.setAttribute('data-scrolled', String(isScrolled));
	}
	
	window.addEventListener('scroll', updateHeaderScroll, { passive: true });
	updateHeaderScroll();

	// Mobile menu toggle
	const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
	const mobileMenu = document.getElementById('mobile-menu');
	const mobilePanel = document.getElementById('mobile-panel');
	const mobileBackdrop = document.getElementById('mobile-backdrop');
	const menuIcon = document.getElementById('menu-icon');
	const closeIcon = document.getElementById('close-icon');
	const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
	const mobileCta = document.getElementById('mobile-cta');

	function openMobileMenu() {
		mobileMenu?.classList.add('open');
		mobilePanel?.classList.add('open');
		menuIcon?.classList.add('hidden');
		closeIcon?.classList.remove('hidden');
		document.body.style.overflow = 'hidden';

		// Animate nav links with stagger
		mobileNavLinks.forEach((link, index) => {
			setTimeout(() => {
				link.classList.add('animate');
			}, index * 50);
		});

		// Animate CTA
		setTimeout(() => {
			mobileCta?.classList.add('animate');
		}, 300);
	}

	function closeMobileMenu() {
		mobileMenu?.classList.remove('open');
		mobilePanel?.classList.remove('open');
		menuIcon?.classList.remove('hidden');
		closeIcon?.classList.add('hidden');
		document.body.style.overflow = '';

		// Reset animations
		mobileNavLinks.forEach((link) => {
			link.classList.remove('animate');
		});
		mobileCta?.classList.remove('animate');
	}

	mobileMenuToggle?.addEventListener('click', () => {
		const isOpen = mobileMenu?.classList.contains('open');
		if (isOpen) {
			closeMobileMenu();
		} else {
			openMobileMenu();
		}
	});

	mobileBackdrop?.addEventListener('click', closeMobileMenu);

	// Close mobile menu on nav link click
	mobileNavLinks.forEach((link) => {
		link.addEventListener('click', closeMobileMenu);
	});

	// Smooth scroll to sections
	function scrollToSection(href: string) {
		const element = document.querySelector(href);
		if (element) {
			element.scrollIntoView({ behavior: 'smooth' });
		}
	}

	// Desktop nav links smooth scroll
	document.querySelectorAll('.nav-link').forEach((link) => {
		link.addEventListener('click', (e) => {
			e.preventDefault();
			const href = link.getAttribute('href');
			if (href) {
				scrollToSection(href);
			}
		});
	});

	// Mobile nav links smooth scroll
	mobileNavLinks.forEach((link) => {
		if (link.getAttribute('href')?.startsWith('#')) {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const href = link.getAttribute('href');
				if (href) {
					scrollToSection(href);
					closeMobileMenu();
				}
			});
		}
	});

	// Booking CTA buttons
	const bookingCtaDesktop = document.getElementById('booking-cta-desktop');
	const bookingCtaMobile = document.getElementById('booking-cta-mobile');

	function scrollToBooking() {
		const element = document.querySelector('#booking');
		if (element) {
			element.scrollIntoView({ behavior: 'smooth' });
		}
	}

	bookingCtaDesktop?.addEventListener('click', scrollToBooking);
	bookingCtaMobile?.addEventListener('click', () => {
		scrollToBooking();
		closeMobileMenu();
	});
</script>