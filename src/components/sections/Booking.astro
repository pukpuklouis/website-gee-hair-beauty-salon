---
const lineIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>`;
const phoneIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>`;
const externalIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" x2="21" y1="14" y2="3"></line></svg>`;
const mapPinIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>`;
const clockIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`;
const creditCardIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" x2="23" y1="10" y2="10"></line></svg>`;
---

<section id="booking" class="relative py-24 lg:py-32 bg-[hsl(var(--soft-cream))] overflow-hidden">
  <!-- Background Decorations -->
  <div class="absolute top-0 left-0 w-96 h-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[hsl(var(--blush-mist))]/5 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 translate-x-1/2 translate-y-1/2 rounded-full bg-[hsl(var(--muted-bronze))]/5 blur-3xl pointer-events-none"></div>

  <div class="relative z-10 px-6 sm:px-8 lg:px-16 xl:px-24">
    <div class="max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <div class="flex items-center justify-center gap-3 mb-6">
          <div class="w-12 h-[1px] bg-[hsl(var(--muted-bronze))]"></div>
          <span class="text-sm tracking-[0.2em] uppercase text-[hsl(var(--muted-bronze))]">
            Booking
          </span>
          <div class="w-12 h-[1px] bg-[hsl(var(--muted-bronze))]"></div>
        </div>

        <h2 class="text-4xl lg:text-5xl font-medium text-[hsl(var(--deep-espresso))] mb-4">
          立即預約
        </h2>

        <p class="text-[hsl(var(--deep-espresso))]/70 max-w-2xl mx-auto">
          選擇最方便的方式預約，我們期待為您服務
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Left: CTA Cards -->
        <div class="space-y-6">
          <!-- LINE Booking -->
          <div class="group relative bg-gradient-to-br from-[#06C755] to-[#05a347] rounded-2xl p-8 text-white overflow-hidden transition-all duration-1000 animate-fade-in-up" style="animation-delay: 300ms">
            <div class="relative z-10">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 rounded-xl bg-white/20 flex items-center justify-center">
                  <Fragment set:html={lineIcon} />
                </div>
                <div>
                  <h3 class="text-xl font-medium">LINE 預約</h3>
                  <p class="text-white/80 text-sm">最快速的預約方式</p>
                </div>
              </div>
              <p class="text-white/90 mb-6">
                加入我們的 LINE 官方帳號，直接與設計師溝通，隨時隨地輕鬆預約
              </p>
              <a
                href="https://lin.ee/WoerF3s"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center bg-white text-[#06C755] hover:bg-white/90 px-6 py-5 rounded-full font-medium transition-all duration-300 group-hover:shadow-lg"
              >
                加入 LINE 預約
                <Fragment set:html={externalIcon} class="ml-2" />
              </a>
            </div>
            <!-- Decorative Circle -->
            <div class="absolute -right-8 -bottom-8 w-32 h-32 rounded-full bg-white/10"></div>
          </div>

          <!-- Phone Booking -->
          <div class="group relative bg-white rounded-2xl p-8 border border-[hsl(var(--muted-bronze))]/10 overflow-hidden transition-all duration-1000 animate-fade-in-up" style="animation-delay: 400ms">
            <div class="relative z-10">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 rounded-xl bg-[hsl(var(--muted-bronze))]/10 flex items-center justify-center">
                  <Fragment set:html={phoneIcon} class="text-[hsl(var(--muted-bronze))]" />
                </div>
                <div>
                  <h3 class="text-xl font-medium text-[hsl(var(--deep-espresso))]">電話預約</h3>
                  <p class="text-[hsl(var(--deep-espresso))]/60 text-sm">直接與我們聯繫</p>
                </div>
              </div>
              <p class="text-[hsl(var(--deep-espresso))]/70 mb-6">
                有任何問題或特殊需求，歡迎直接來電諮詢
              </p>
              <a
                href="tel:+886-2-6605-8387"
                class="inline-flex items-center justify-center border border-[hsl(var(--muted-bronze))] text-[hsl(var(--muted-bronze))] hover:bg-[hsl(var(--muted-bronze))] hover:text-white px-6 py-5 rounded-full transition-all duration-300"
              >
                <Fragment set:html={phoneIcon} class="w-4 h-4 mr-2" />
                02-66058387
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Info Card -->
        <div class="bg-white rounded-2xl p-8 border border-[hsl(var(--muted-bronze))]/10 transition-all duration-1000 animate-fade-in-up" style="animation-delay: 500ms">
          <h3 class="text-xl font-medium text-[hsl(var(--deep-espresso))] mb-6">
            店家資訊
          </h3>

          <div class="space-y-6">
            <!-- Address -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-[hsl(var(--warm-beige))] flex items-center justify-center flex-shrink-0">
                <Fragment set:html={mapPinIcon} class="text-[hsl(var(--muted-bronze))]" />
              </div>
              <div>
                <p class="font-medium text-[hsl(var(--deep-espresso))] mb-1">地址</p>
                <p class="text-[hsl(var(--deep-espresso))]/70 text-sm">
                  台北市大安區通化街19巷5號1樓
                </p>
                <p class="text-[hsl(var(--blush-mist))] text-sm mt-1">
                  信義安和站 3 號出口步行 3 分鐘
                </p>
                <a
                  href="https://maps.app.goo.gl/YULd3Q2zgcCwyfY6A?g_st=ic"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-[hsl(var(--muted-bronze))] hover:underline mt-2 inline-flex items-center gap-1"
                >
                  查看地圖
                  <Fragment set:html={externalIcon} class="w-3 h-3" />
                </a>
              </div>
            </div>

            <!-- Hours -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-[hsl(var(--warm-beige))] flex items-center justify-center flex-shrink-0">
                <Fragment set:html={clockIcon} class="text-[hsl(var(--muted-bronze))]" />
              </div>
              <div>
                <p class="font-medium text-[hsl(var(--deep-espresso))] mb-1">營業時間</p>
                <div class="text-[hsl(var(--deep-espresso))]/70 text-sm space-y-1">
                  <p>週三 - 週六: 12:00 - 19:00</p>
                  <p>週日: 12:00 - 18:00</p>
                  <p class="text-[hsl(var(--blush-mist))]">週一、週二公休</p>
                </div>
              </div>
            </div>

            <!-- Payment -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-[hsl(var(--warm-beige))] flex items-center justify-center flex-shrink-0">
                <Fragment set:html={creditCardIcon} class="text-[hsl(var(--muted-bronze))]" />
              </div>
              <div>
                <p class="font-medium text-[hsl(var(--deep-espresso))] mb-1">付款方式</p>
                <p class="text-[hsl(var(--deep-espresso))]/70 text-sm">
                  現金付款（建議提前預約）
                </p>
              </div>
            </div>

            <!-- Note -->
            <div class="mt-6 p-4 bg-[hsl(var(--blush-mist))]/10 rounded-xl">
              <p class="text-sm text-[hsl(var(--blush-mist))]">
                溫馨提醒：建議提前 3-7 天預約，假日時段較為熱門，請盡早預約以确保理想時段
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
    opacity: 0;
  }
</style>
