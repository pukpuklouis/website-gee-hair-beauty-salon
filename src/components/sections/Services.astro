---

<section id="services" class="relative py-24 lg:py-32 bg-[hsl(var(--soft-cream))] overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-[hsl(var(--blush-mist))]/5 to-transparent pointer-events-none"></div>

  <div class="relative z-10 px-6 sm:px-8 lg:px-16 xl:px-24">
    <!-- Section Header -->
    <div class="text-center mb-16 animate-fade-in-up">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="w-12 h-[1px] bg-[hsl(var(--muted-bronze))]"></div>
        <span class="text-sm tracking-[0.2em] uppercase text-[hsl(var(--muted-bronze))]">
          Our Services
        </span>
        <div class="w-12 h-[1px] bg-[hsl(var(--muted-bronze))]"></div>
      </div>

      <h2 class="text-4xl lg:text-5xl font-medium text-[hsl(var(--deep-espresso))] mb-4">
        我們的服務
      </h2>

      <p class="text-[hsl(var(--deep-espresso))]/70 max-w-2xl mx-auto">
        為現代個體打造的精緻服務，從髮絲到指尖，全方位呵護您的美麗
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {services.map((service, index) => (
        <div
          class="group relative bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 ease-custom-expo animate-fade-in-up"
          style={`animation-delay: ${300 + index * 100}ms`}
        >
          <!-- Image -->
          <div class="relative aspect-[16/10] overflow-hidden">
            <img
              src={service.image}
              alt={service.title}
              class="w-full h-full object-cover transition-transform duration-700 ease-custom-expo group-hover:scale-110"
            />
            <!-- Gradient Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>

            <!-- Icon Badge -->
            <div class="absolute top-4 left-4 w-10 h-10 rounded-full bg-white/90 backdrop-blur-sm flex items-center justify-center text-[hsl(var(--muted-bronze))]">
              <Fragment set:html={iconSvgs[service.icon]} />
            </div>

            <!-- Title on Image -->
            <div class="absolute bottom-4 left-4 right-4">
              <h3 class="text-xl font-medium text-white mb-1">
                {service.title}
              </h3>
              <p class="text-sm text-white/80 font-accent italic">
                {service.subtitle}
              </p>
            </div>
          </div>

          <!-- Content -->
          <div class="p-6">
            <p class="text-[hsl(var(--deep-espresso))]/70 text-sm leading-relaxed mb-4">
              {service.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
              {service.tags.map((tag) => (
                <span class="service-tag px-3 py-1 rounded-full text-xs bg-[hsl(var(--warm-beige))] text-[hsl(var(--muted-bronze))] transition-all duration-300">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <!-- Hover Border Effect -->
          <div class="service-border absolute inset-0 border-2 rounded-2xl border-transparent transition-all duration-300 pointer-events-none"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
    opacity: 0;
  }

  .group:hover .service-tag {
    background-color: hsl(var(--blush-mist) / 0.2);
    color: hsl(var(--blush-mist));
  }

  .group:hover .service-border {
    border-color: hsl(var(--blush-mist) / 0.5);
  }
</style>
