---
const features = [
  {
    title: '專業技術',
    description: '每位設計師皆經過嚴格培訓，掌握最新韓系髮型趨勢',
  },
  {
    title: '溫暖服務',
    description: '像朋友一樣傾聽您的需求，給予最適合的建議',
  },
  {
    title: '友善空間',
    description: 'LGBTQ+ 友善環境，每個人都能自在地展現自己',
  },
];
---

<section
  id="about"
  class="relative py-24 lg:py-32 bg-[hsl(var(--warm-beige))] overflow-hidden"
>
  {/* Decorative Background */}
  <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-[hsl(var(--warm-beige))] to-transparent"></div>

  {/* Large Background Text */}
  <div
    data-animate
    class="absolute top-1/2 left-0 -translate-y-1/2 font-display text-[20vw] font-bold text-[hsl(var(--muted-bronze))]/5 whitespace-nowrap pointer-events-none select-none transition-all duration-1000 opacity-0 -translate-x-20"
  >
    ABOUT
  </div>

  <div class="relative z-10 px-6 sm:px-8 lg:px-16 xl:px-24">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      {/* Left: Image */}
      <div
        data-animate
        data-delay="0"
        class="relative transition-all duration-1000 opacity-0 -translate-x-12"
      >
        <div class="relative aspect-[4/5] rounded-2xl overflow-hidden">
          <img
            src="/salon-intro.jpg"
            alt="Gee Hair Salon"
            class="w-full h-full object-cover"
          />
          {/* Overlay gradient */}
          <div class="absolute inset-0 bg-gradient-to-t from-[hsl(var(--deep-espresso))]/30 to-transparent"></div>
        </div>

        {/* Floating Card */}
        <div
          data-animate
          data-delay="300"
          class="absolute -bottom-8 -right-8 bg-white rounded-xl p-6 shadow-xl max-w-[240px] transition-all duration-1000 opacity-0 translate-y-8"
        >
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-[hsl(var(--blush-mist))]/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-[hsl(var(--blush-mist))]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
              </svg>
            </div>
            <span class="font-medium text-[hsl(var(--deep-espresso))]">5.0 評分</span>
          </div>
          <p class="text-sm text-[hsl(var(--deep-espresso))]/70">
            超過 500+ 位顧客的真實好評
          </p>
        </div>

        {/* Decorative Frame */}
        <div class="absolute -top-4 -left-4 w-full h-full border-2 border-[hsl(var(--muted-bronze))]/20 rounded-2xl -z-10"></div>
      </div>

      {/* Right: Content */}
      <div class="lg:pl-8">
        {/* Section Label */}
        <div
          data-animate
          data-delay="200"
          class="flex items-center gap-3 mb-6 transition-all duration-1000 opacity-0 translate-y-8"
        >
          <div class="w-12 h-[1px] bg-[hsl(var(--muted-bronze))]"></div>
          <span class="text-sm tracking-[0.2em] uppercase text-[hsl(var(--muted-bronze))]">
            About Us
          </span>
        </div>

        {/* Title */}
        <h2
          data-animate
          data-delay="300"
          class="text-4xl lg:text-5xl font-medium text-[hsl(var(--deep-espresso))] mb-6 leading-tight transition-all duration-1000 opacity-0 translate-y-8"
        >
          走進巷弄裡的
          <br />
          <span class="font-accent italic text-[hsl(var(--muted-bronze))]">質感小店</span>
        </h2>

        {/* Description */}
        <div
          data-animate
          data-delay="400"
          class="space-y-4 mb-10 transition-all duration-1000 opacity-0 translate-y-8"
        >
          <p class="text-[hsl(var(--deep-espresso))]/80 leading-relaxed">
            Gee 聚沙龍不僅僅是一家髮廊——它是您美麗旅程的聖地。我們技藝精湛的設計師將現代潮流與永恆優雅相融合，打造專屬於您的造型。
          </p>
          <p class="text-[hsl(var(--deep-espresso))]/70 leading-relaxed">
            我們相信，美髮不應該是高冷的體驗。在 Gee，您會感受到像走進巷弄裡的質感小店那樣——有格調但不高傲，專業但不失人情味。
          </p>
        </div>

        {/* Features */}
        <div
          data-animate
          data-delay="500"
          class="grid gap-6 transition-all duration-1000 opacity-0 translate-y-8"
        >
          {features.map((feature, index) => (
            <div
              key={feature.title}
              class="flex items-start gap-4 p-4 rounded-xl bg-white/50 hover:bg-white/80 transition-all duration-300 group"
              style={`animation-delay: ${0.6 + index * 0.1}s`}
            >
              <div class="w-12 h-12 rounded-xl bg-[hsl(var(--muted-bronze))]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[hsl(var(--muted-bronze))]/20 transition-colors">
                {index === 0 && (
                  <svg class="w-6 h-6 text-[hsl(var(--muted-bronze))]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
                  </svg>
                )}
                {index === 1 && (
                  <svg class="w-6 h-6 text-[hsl(var(--muted-bronze))]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                )}
                {index === 2 && (
                  <svg class="w-6 h-6 text-[hsl(var(--muted-bronze))]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                  </svg>
                )}
              </div>
              <div>
                <h3 class="font-medium text-[hsl(var(--deep-espresso))] mb-1">
                  {feature.title}
                </h3>
                <p class="text-sm text-[hsl(var(--deep-espresso))]/70">
                  {feature.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = el.dataset.delay || '0';
            setTimeout(() => {
              el.classList.remove('opacity-0', '-translate-x-12', '-translate-x-20', 'translate-y-8');
            }, parseInt(delay));
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.2 }
    );

    document.querySelectorAll('[data-animate]').forEach((el) => {
      observer.observe(el);
    });
  });
</script>
