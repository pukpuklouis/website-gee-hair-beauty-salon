---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';
import Hero from '../components/sections/Hero';
import About from '../components/sections/About.astro';
import Services from '../components/sections/Services.astro';
import Portfolio from '../components/sections/Portfolio';
import Designers from '../components/sections/Designers.astro';
import Testimonials from '../components/sections/Testimonials';
import Booking from '../components/sections/Booking.astro';
---

<BaseLayout title="Gee Hair Salon - 專業美髮沙龍" description="專業美髮沙龍，提供染髮、護髮、剪髮等服務">
	<SEO
		title="Gee Hair Salon - 專業美髮沙龍"
		description="專業美髮沙龍，提供染髮、護髮、剪髮等服務"
		keywords="美髮,沙龍,染髮,護髮,剪髮,Gee Hair"
	/>
	<Schema type="LocalBusiness" />
	<Hero client:visible />
	<About />
	<Services />
	<Portfolio client:visible />
	<Designers />
	<Testimonials client:visible />
	<Booking />
</BaseLayout>