										{featuredPost.data.title}
									</h2>

									<p class="text-[hsl(var(--deep-espresso))]/60 leading-relaxed mb-6">
										{featuredPost.data.description}
									</p>

									<div class="flex items-center justify-between">
										<div class="flex items-center gap-3">
											{featuredPost.data.authorImage ? (
												<img
													src={featuredPost.data.authorImage}
													alt={featuredPost.data.author || 'Gee Hair'}
													class="w-10 h-10 rounded-full object-cover bg-[hsl(var(--warm-beige))]"
												/>
											) : (
												<div class="w-10 h-10 rounded-full bg-[hsl(var(--warm-beige))] flex items-center justify-center text-[hsl(var(--muted-bronze))] text-sm font-medium">
													G
												</div>
											)}
											<span class="text-sm text-[hsl(var(--deep-espresso))]/70">
												{featuredPost.data.author || 'Gee Hair'}
											</span>
										</div>

										<span class="flex items-center gap-2 text-[hsl(var(--muted-bronze))] font-medium group-hover:gap-3 transition-all">
											閱讀更多
											<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
											</svg>
										</span>
									</div>
								</div>
							</div>
						</a>
					</div>
				</div>
			</section>
		)}

		<!-- Blog Grid -->
		<section class="py-12 lg:py-16">
			<div class="px-6 sm:px-8 lg:px-16 xl:px-24">
				<div class="max-w-6xl mx-auto">
					<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8" id="blog-grid">
						{regularPosts.map((post, index) => (
							<a
								href={`/blog/${post.id}/`}
								class="blog-card group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 opacity-0 translate-y-12"
								data-category={getCategory(post)}
								style={`transition-delay: ${index * 100}ms`}
							>
								<div class="relative aspect-[16/10] overflow-hidden">
									{post.data.heroImage && (
										<img
											src={post.data.heroImage}
											alt={post.data.title || ''}
											class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
											loading="lazy"
										/>
									)}
									<div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
									<div class="absolute top-4 left-4">
										<span class="px-3 py-1 bg-white/90 backdrop-blur-sm rounded-full text-xs text-[hsl(var(--muted-bronze))]">
											{getCategory(post)}
										</span>
									</div>
								</div>

								<div class="p-6">
									<div class="flex items-center gap-3 text-xs text-[hsl(var(--deep-espresso))]/50 mb-3">
										<span class="flex items-center gap-1">
											<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-6 8h8m-8 4h8m-4-4v4m0 0v4m0-4h4m-4 0H8m8 0h4m-4 0v4m0-4V8m0 8v4m0-4h4m-4 0H8"></path>
											</svg>
											<FormattedDate date={post.data.pubDate} />
										</span>
										<span class="flex items-center gap-1">
											<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
											</svg>
											{post.data.readTime || '5 分鐘'}
										</span>
									</div>

									<h3 class="text-lg font-medium text-[hsl(var(--deep-espresso))] mb-2 group-hover:text-[hsl(var(--muted-bronze))] transition-colors line-clamp-2">
										{post.data.title}
									</h3>

									<p class="text-sm text-[hsl(var(--deep-espresso))]/60 line-clamp-2 mb-4">
										{post.data.description}
									</p>

<div class="flex items-center gap-2">
										{post.data.authorImage ? (
											<img
                                                src={post.data.authorImage}
                                                alt={post.data.author || 'Author'}
                                                class="w-7 h-7 rounded-full object-cover bg-[hsl(var(--warm-beige))]"
                                            />
                                        ) : (
                                            <div class="w-7 h-7 rounded-full bg-[hsl(var(--warm-beige))] flex items-center justify-center text-[hsl(var(--muted-bronze))] text-xs font-medium">
                                                G
                                            </div>
                                        )}
                                        <span class="text-xs text-[hsl(var(--deep-espresso))]/60">
                                            {post.data.author || 'Gee Hair'}
                                        </span>
                                    </div>
								</div>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Newsletter Section -->
		<section class="py-16 lg:py-24 bg-[hsl(var(--soft-cream))]">
			<div class="px-6 sm:px-8 lg:px-16 xl:px-24">
				<div class="max-w-2xl mx-auto text-center">
					<h2 class="text-2xl lg:text-3xl font-medium text-[hsl(var(--deep-espresso))] mb-4">
						訂閱我們的美髮日誌
					</h2>
					<p class="text-[hsl(var(--deep-espresso))]/70 mb-8">
						第一時間獲取最新的染髮趨勢、護髮知識與獨家優惠
					</p>
					<form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto" id="newsletter-form">
						<input
							type="email"
							placeholder="輸入您的電子郵件"
							class="flex-1 px-5 py-3 rounded-full border border-[hsl(var(--muted-bronze))]/20 bg-white focus:outline-none focus:border-[hsl(var(--muted-bronze))] transition-colors"
							required
						/>
						<button 
							type="submit"
							class="px-6 py-3 bg-[hsl(var(--muted-bronze))] text-white rounded-full hover:bg-[hsl(var(--deep-espresso))] transition-colors"
						>
							訂閱
						</button>
					</form>
				</div>
			</div>
		</section>
	</div>
</BaseLayout>

<script>
	type BlogPageState = {
		observer?: IntersectionObserver;
		abortController?: AbortController;
		handlePageLoad?: () => void;
		handleBeforeSwap?: () => void;
	};

	const windowWithBlogPageState = window as Window & {
		__blogPageState?: BlogPageState;
	};
	const blogPageState = windowWithBlogPageState.__blogPageState ??= {};

	const inactiveButtonClasses = ['bg-white/60', 'text-[hsl(var(--muted-bronze))]'];
	const activeButtonClasses = ['bg-[hsl(var(--muted-bronze))]', 'text-white'];
	const hiddenRevealClasses = ['opacity-0', 'translate-y-12'];
	const visibleRevealClasses = ['opacity-100', 'translate-y-0'];

	const revealElement = (element: Element) => {
		element.classList.remove(...hiddenRevealClasses);
		element.classList.add(...visibleRevealClasses);
	};

	const resetRevealElement = (element: Element) => {
		element.classList.remove(...visibleRevealClasses);
		element.classList.add(...hiddenRevealClasses);
	};

	const isElementInViewport = (element: Element) => {
		const rect = element.getBoundingClientRect();
		return rect.top < window.innerHeight - 50 && rect.bottom > 0;
	};

	const cleanupBlogPage = () => {
		blogPageState.abortController?.abort();
		blogPageState.observer?.disconnect();
		blogPageState.abortController = undefined;
		blogPageState.observer = undefined;
	};

	const initBlogPage = () => {
		cleanupBlogPage();

		const categoryBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.category-btn'));
		const blogCards = Array.from(document.querySelectorAll<HTMLElement>('.blog-card'));
		const featuredSection = document.getElementById('featured-section');
		const featuredCard = document.getElementById('featured-card');
		const newsletterForm = document.getElementById('newsletter-form') as HTMLFormElement | null;

		if (!categoryBtns.length && !blogCards.length && !featuredCard && !newsletterForm) {
			return;
		}

		const abortController = new AbortController();
		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (!entry.isIntersecting) return;
				revealElement(entry.target);
				observer.unobserve(entry.target);
			});
		}, {
			threshold: 0.1,
			rootMargin: '0px 0px -50px 0px'
		});

		blogPageState.abortController = abortController;
		blogPageState.observer = observer;

		const syncRevealTarget = (element: HTMLElement | null, shouldShow = true) => {
			if (!element) return;

			if (!shouldShow) {
				observer.unobserve(element);
				return;
			}

			if (element.style.display === 'none') {
				return;
			}

			if (element.classList.contains('opacity-100')) {
				observer.unobserve(element);
				return;
			}

			if (isElementInViewport(element)) {
				revealElement(element);
				observer.unobserve(element);
				return;
			}

			observer.observe(element);
		};

		const setActiveCategory = (category: string) => {
			categoryBtns.forEach((button) => {
				const isActive = button.dataset.category === category;
				button.classList.toggle(activeButtonClasses[0], isActive);
				button.classList.toggle(activeButtonClasses[1], isActive);
				button.classList.toggle(inactiveButtonClasses[0], !isActive);
				button.classList.toggle(inactiveButtonClasses[1], !isActive);
			});

			blogCards.forEach((card) => {
				const shouldShow = category === '全部' || card.dataset.category === category;
				card.style.display = shouldShow ? 'block' : 'none';
				syncRevealTarget(card, shouldShow);
			});

			if (featuredSection) {
				const showFeatured = category === '全部';
				featuredSection.style.display = showFeatured ? 'block' : 'none';
				syncRevealTarget(featuredCard as HTMLElement | null, showFeatured);
			}
		};

		[featuredCard, ...blogCards].forEach((element) => {
			if (!element || element.classList.contains('opacity-100')) {
				return;
			}
			resetRevealElement(element);
		});

		setActiveCategory('全部');

		categoryBtns.forEach((button) => {
			button.addEventListener('click', () => {
				setActiveCategory(button.dataset.category || '全部');
			}, { signal: abortController.signal });
		});

		newsletterForm?.addEventListener('submit', (event) => {
			event.preventDefault();
			const emailInput = newsletterForm.querySelector('input[type="email"]') as HTMLInputElement | null;
			if (!emailInput?.value) return;
			alert('感謝您的訂閱！');
			emailInput.value = '';
		}, { signal: abortController.signal });
	};

	if (blogPageState.handlePageLoad) {
		document.removeEventListener('astro:page-load', blogPageState.handlePageLoad);
	}

	if (blogPageState.handleBeforeSwap) {
		document.removeEventListener('astro:before-swap', blogPageState.handleBeforeSwap);
	}

	const handlePageLoad = () => {
		requestAnimationFrame(() => {
			initBlogPage();
		});
	};

	const handleBeforeSwap = () => {
		cleanupBlogPage();
	};

	blogPageState.handlePageLoad = handlePageLoad;
	blogPageState.handleBeforeSwap = handleBeforeSwap;
	document.addEventListener('astro:page-load', handlePageLoad);
	document.addEventListener('astro:before-swap', handleBeforeSwap);

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', handlePageLoad, { once: true });
	} else {
		handlePageLoad();
	}
</script>

<style>
	/* Hide scrollbar utility */
	.hide-scrollbar {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	
	.hide-scrollbar::-webkit-scrollbar {
		display: none;
	}
	
	/* Line clamp utilities */
	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	
	/* Noise overlay */
	.noise-overlay::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
		opacity: 0.03;
		pointer-events: none;
		z-index: 1;
	}
</style>