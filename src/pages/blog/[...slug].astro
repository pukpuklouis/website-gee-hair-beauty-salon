---
import { client } from "../../../tina/__generated__/client";
import BlogPostRenderer from "../../components/BlogPostRenderer.tsx";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
	const response = await client.queries.blogConnection();
	return (
		response.data?.blogConnection?.edges
			?.filter((edge): edge is NonNullable<typeof edge> => edge != null && edge.node != null)
			.map((edge) => ({
				params: { slug: edge.node._sys.filename },
			})) ?? []
	);
}

const { slug } = Astro.params;

let response: Awaited<ReturnType<typeof client.queries.blog>>;
try {
	response = await client.queries.blog({
		relativePath: `${slug}.mdx`,
	});
} catch (e) {
	console.error("[blog/[...slug]] TinaCMS query failed:", e);
	return Astro.redirect("/blog");
}

const { data, query, variables } = response;
const blog = data.blog;

const relatedResponse = await client.queries.blogConnection();
const _relatedPosts =
	relatedResponse.data?.blogConnection?.edges
		?.filter((edge): edge is NonNullable<typeof edge> => edge != null && edge.node != null)
		.filter((edge) => edge.node._sys.filename !== slug)
		.sort((a, b) => {
			const dateA = a.node.pubDate ? new Date(a.node.pubDate).getTime() : 0;
			const dateB = b.node.pubDate ? new Date(b.node.pubDate).getTime() : 0;
			return dateB - dateA;
		})
		.slice(0, 3)
		.map((edge) => ({
			id: edge.node._sys.filename,
			data: {
				title: edge.node.title,
				heroImage: edge.node.heroImage,
				category: edge.node.category,
				pubDate: edge.node.pubDate ?? "",
			},
		})) ?? [];

const title = blog.title ?? "Blog Post";
const description = blog.description ?? "";
---

<BaseLayout title={`${title} | Gee Hair Salon`} description={description}>
  <BlogPostRenderer
    client:tina
    data={data}
    query={query}
    variables={variables}
    relatedPosts={_relatedPosts}
  />
</BaseLayout>
